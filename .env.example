# Default model used when client omits "model" field in request
MODEL_NAME=qwen2.5-3b

# Root directory containing per-model LoRA adapter folders
# (must match the structure: $ADAPTER_DIR/<model_key>/adapter_config.json)
ADAPTER_DIR=adapters

# HuggingFace cache (base models are downloaded here on first run)
HF_HOME=/app/models_cache
TRANSFORMERS_CACHE=/app/models_cache

# Logging
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Generation
MAX_NEW_TOKENS=2048
GENERATION_TIMEOUT_S=120

# CORS — comma-separated list, or "*" for all origins (dev only)
CORS_ORIGINS=*

# Force CPU even if CUDA is available (debug only)
FORCE_CPU=false

# HF token if any model is private/gated
# HF_TOKEN=

# ---- SAYIT integration -------------------------------------------------------
SERVICE_NAME=exercise-generator
SAYIT_INTEGRATION=false
SAYIT_BACKEND_URL=http://backend:8000
